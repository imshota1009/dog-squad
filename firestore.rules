rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /dog_squad_rooms/{code} {
      allow read, write: if true;
      match /relay/{playerId} {
        allow read, write: if true;
      }
    }
    // DDA data collection — write-only for players, read for admin
    match /dda_sessions/{sessionId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
